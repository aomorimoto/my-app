# API テスト（vitest + supertest）用の環境変数のサンプル。
# このファイルをコピーして `.env.test` を作成してください（`.env.test` は .gitignore 済み）。
#
# ⚠️ 重要: DATABASE_URL には「使い捨てのテスト専用 DB」を指定すること。
#          本番／共有 DB（.env の DATABASE_URL）は絶対に入れないでください。
#          test/setup.ts が .env と一致した場合は即座にテストを中止します。
#
# 例（ローカル Postgres にテスト用 DB を作る場合）:
#   createdb taskapp_test
#   DATABASE_URL="postgres://postgres:postgres@localhost:5432/taskapp_test"

DATABASE_URL="postgres://postgres:postgres@localhost:5432/taskapp_test"

# ローカル Postgres は通常 SSL 非対応なので無効化（本番のみ SSL 有効）。
DATABASE_SSL="false"

# セッション署名用（テストでは任意の値でよい）。
SESSION_SECRET="test-session-secret"

# CSRF トークン署名用（任意）。未設定なら SESSION_SECRET を流用するので通常は不要。
# CSRF_SECRET="test-csrf-secret"
