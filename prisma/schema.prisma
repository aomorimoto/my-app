// タスク管理アプリの Prisma スキーマ
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// アプリ利用者アカウント
model User {
  id              Int          @id @default(autoincrement())
  email           String       @unique
  password        String // bcrypt でハッシュ化したパスワード
  name            String?
  createdAt       DateTime     @default(now())
  memberships     Membership[] // 所属するワークスペース
  ownedWorkspaces Workspace[]  @relation("WorkspaceOwner")
  createdTasks    Task[]       @relation("TaskCreator")
  assignedTasks   Task[]       @relation("TaskAssignee")
  comments        Comment[]    @relation("CommentAuthor")
}

// 共有空間（チーム/プロジェクト）。データの所有単位。
model Workspace {
  id         Int          @id @default(autoincrement())
  name       String
  ownerId    Int
  owner      User         @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  createdAt  DateTime     @default(now())
  members    Membership[]
  categories Category[]
  tasks      Task[]
  tags       Tag[]
}

// ワークスペースへの参加者と役割
model Membership {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        Role      @default(MEMBER)
  joinedAt    DateTime  @default(now())

  @@unique([userId, workspaceId])
}

// タスクを分類するカテゴリ（ワークスペースごとに作成）
model Category {
  id          Int       @id @default(autoincrement())
  name        String
  color       String    @default("#888888") // UI 表示用の色（HEX）
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]
}

// タスク
model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  status      Status    @default(TODO)
  priority    Priority  @default(MEDIUM)
  dueDate     DateTime?
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creatorId   Int // 作成者
  creator     User      @relation("TaskCreator", fields: [creatorId], references: [id])
  assigneeId  Int? // 担当者（未割当は null）。API/UI 連携は Phase 3b。
  assignee    User?     @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  parentId    Int? // 親タスク（サブタスク時に設定）。2階層のみ許可。
  parent      Task?     @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]    @relation("Subtasks")
  taskTags    TaskTag[]
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// タグ（ワークスペースごと）。カテゴリ（1タスク1つ）とは別軸で、1タスクに複数付与できる。
model Tag {
  id          Int       @id @default(autoincrement())
  name        String
  color       String    @default("#888888") // UI 表示用の色（HEX）
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  taskTags    TaskTag[]

  @@unique([workspaceId, name]) // WS 内でタグ名の重複を禁止
}

// Task ↔ Tag の多対多中間テーブル
model TaskTag {
  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  Int
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

// タスクへのコメント（スレッド表示用）
model Comment {
  id        Int      @id @default(autoincrement())
  body      String
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  Int
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// express-session のセッション保管用テーブル（connect-pg-simple 互換）
// Prisma に管理させることで起動時の自動 DDL を不要にし、スキーマのドリフトを防ぐ
model Session {
  sid    String   @id
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}

// ワークスペース内の役割（権限は design.md §6 を参照）
enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}

// 並び順が「高 → 低」になるように定義（enum の定義順 = DB のソート順）
enum Priority {
  HIGH
  MEDIUM
  LOW
}
