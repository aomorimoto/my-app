// タスク管理アプリの Prisma スキーマ
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// アプリ利用者アカウント
model User {
  id              Int          @id @default(autoincrement())
  username        String       @unique // ログイン識別子（英小文字・数字・_ . - の 3〜30 文字）
  password        String // bcrypt でハッシュ化したパスワード
  name            String?
  avatarColor     String? // アバターの単色背景（#RRGGBB）。未設定なら既定色をアプリ側で決める
  avatarImage     String? // アップロードしたアバター画像（data URI。未設定なら色+頭文字を表示）
  colorPrefs      Json? // 状態/優先度/期限の表示色の個人設定（キー→#RRGGBB）。未設定は既定色
  createdAt       DateTime     @default(now())
  memberships     Membership[] // 所属するワークスペース
  ownedWorkspaces Workspace[]  @relation("WorkspaceOwner")
  createdTasks    Task[]       @relation("TaskCreator")
  assignedTasks   Task[]       @relation("TaskAssignee")
  agents          Agent[]      @relation("AgentOwner") // 本人が使う AI エージェント
  comments        Comment[]    @relation("CommentAuthor")
  // リモート MCP の OAuth（自前認可サーバ）で発行する認可コード/トークン
  oauthAuthorizationCodes OAuthAuthorizationCode[]
  oauthAccessTokens       OAuthAccessToken[]
  oauthRefreshTokens      OAuthRefreshToken[]
}

// 共有空間（チーム/プロジェクト）。データの所有単位。
model Workspace {
  id         Int          @id @default(autoincrement())
  name       String
  iconColor  String? // ワークスペースアイコンの単色背景（#RRGGBB）。未設定は既定色
  iconImage  String? // アップロードしたアイコン画像（data URI。未設定は色+頭文字を表示）
  ownerId    Int
  owner      User         @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  createdAt  DateTime     @default(now())
  members    Membership[]
  tasks      Task[]
  tags       Tag[]
  agents     Agent[] // ワークスペースに属する AI エージェント（担当者に指定できる）
}

// ワークスペースへの参加者と役割
model Membership {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        Role      @default(MEMBER)
  joinedAt    DateTime  @default(now())
  position    Int       @default(0) // ユーザーごとのワークスペース表示順（メイン画面の並べ替え用）

  @@unique([userId, workspaceId])
}

// AI エージェント（ワークスペースごと）。人間メンバーと同列に「担当者」に指定できる。
// 1人のユーザーが複数のエージェントを登録し、エージェントごとのタスクを管理するユースケースに対応する。
model Agent {
  id            Int       @id @default(autoincrement())
  name          String
  color         String    @default("#6b7280") // UI 表示用の色（HEX）。画像未設定時の背景色
  iconImage     String? // アップロードしたアイコン画像（data URI。未設定は色＋🤖 を表示）
  workspaceId   Int
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerId       Int? // このエージェントを主に使うユーザー（任意。表示用）
  owner         User?     @relation("AgentOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())
  assignedTasks Task[]    @relation("TaskAgentAssignee")

  @@unique([workspaceId, name]) // WS 内でエージェント名の重複を禁止
}

// タスク
model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  status      Status    @default(TODO)
  priority    Priority  @default(MEDIUM)
  dueDate     DateTime?
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creatorId   Int // 作成者
  creator     User      @relation("TaskCreator", fields: [creatorId], references: [id])
  // 担当者は「人間メンバー(assigneeId)」または「AIエージェント(assigneeAgentId)」のどちらか一方。
  assigneeId      Int? // 担当ユーザー（未割当は null）
  assignee        User?  @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeAgentId Int? // 担当 AI エージェント（未割当は null）
  assigneeAgent   Agent? @relation("TaskAgentAssignee", fields: [assigneeAgentId], references: [id], onDelete: SetNull)
  parentId    Int? // 親タスク（サブタスク時に設定）。多階層のネストを許可（循環のみ禁止）。
  parent      Task?     @relation("Subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks    Task[]    @relation("Subtasks")
  position    Int       @default(0) // 兄弟内の表示順（同一 parent／同一WS内。D&D 並べ替え用）
  // 繰り返し設定（RRULE 風文字列。null=繰り返しなし）。完了トグル時に次回の1件を生成する。
  recurrenceRule     String?
  // 生成元タスクの id（履歴用の soft ポインタ。FK は張らない）。
  recurrenceParentId Int?
  taskTags    TaskTag[]
  comments    Comment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// タグ（ワークスペースごと）。1タスクに複数付与できる分類軸。
model Tag {
  id          Int       @id @default(autoincrement())
  name        String
  color       String    @default("#888888") // UI 表示用の色（HEX）
  workspaceId Int
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  taskTags    TaskTag[]

  @@unique([workspaceId, name]) // WS 内でタグ名の重複を禁止
}

// Task ↔ Tag の多対多中間テーブル
model TaskTag {
  taskId Int
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  Int
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

// タスクへのコメント（スレッド表示用）
model Comment {
  id        Int      @id @default(autoincrement())
  body      String
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  Int
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- リモート MCP 用の OAuth 2.1（自前の認可サーバ兼リソースサーバ）---
// コード/トークンは平文を保存せず SHA-256 ハッシュ（決定的）で保存し逆引きする。
// design.md §8 の「将来はリモート/ホスト型 MCP」を OAuth で具体化したもの。

// OAuth クライアント（Claude が動的クライアント登録 RFC 7591 で自動作成する。基本は公開/PKCE クライアント）。
model OAuthClient {
  id                      Int       @id @default(autoincrement())
  clientId                String    @unique // SDK が生成する client_id
  clientSecretHash        String? // 公開/PKCE クライアントは null（secret を持たない）
  clientSecretExpiresAt   DateTime?
  redirectUris            String[] // 登録済みリダイレクト URI（完全一致で検証）
  tokenEndpointAuthMethod String? // 例: "none"（公開クライアント）
  clientName              String?
  scope                   String?
  grantTypes              String[]
  responseTypes           String[]
  metadata                Json // OAuthClientInformationFull を丸ごと保持（登録レスポンスの往復用）
  createdAt               DateTime  @default(now())
}

// 認可コード（PKCE の code_challenge を保持。単回使用・短寿命）。
model OAuthAuthorizationCode {
  codeHash      String   @id // sha256(code)
  clientId      String
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  redirectUri   String
  codeChallenge String
  scopes        String[]
  resource      String? // RFC 8707 リソースインジケータ
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  @@index([userId])
}

// アクセストークン（Bearer。verifyAccessToken で userId に解決する）。
model OAuthAccessToken {
  tokenHash String   @id // sha256(access_token)
  clientId  String
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes    String[]
  resource  String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// リフレッシュトークン（交換のたびにローテーション）。
model OAuthRefreshToken {
  tokenHash String    @id // sha256(refresh_token)
  clientId  String
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes    String[]
  resource  String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// express-session のセッション保管用テーブル（connect-pg-simple 互換）
// Prisma に管理させることで起動時の自動 DDL を不要にし、スキーマのドリフトを防ぐ
model Session {
  sid    String   @id
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}

// ワークスペース内の役割（権限は design.md §6 を参照）
enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}

// 並び順が「高 → 低」になるように定義（enum の定義順 = DB のソート順）
enum Priority {
  HIGH
  MEDIUM
  LOW
}
