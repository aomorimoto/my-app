<%- include('partials/header', { title: 'カテゴリ管理', currentUser }) %>

<h1>カテゴリ</h1>

<form action="/categories" method="post" class="form card category-form">
  <label class="grow">名前
    <input type="text" name="name" placeholder="カテゴリ名" required />
  </label>
  <label>色
    <input type="color" name="color" value="#888888" />
  </label>
  <button type="submit" class="btn-primary">追加</button>
</form>

<% if (categories.length === 0) { %>
  <p class="empty">カテゴリがまだありません。</p>
<% } else { %>
  <ul class="category-list">
    <% categories.forEach((c) => { %>
      <li class="category-item card">
        <span class="swatch" style="background: <%= c.color %>"></span>
        <span class="category-name"><%= c.name %></span>
        <span class="muted"><%= c._count.tasks %> 件のタスク</span>
        <form action="/categories/<%= c.id %>/delete" method="post" class="inline"
              onsubmit="return confirm('「<%= c.name %>」を削除しますか？（タスクは残ります）');">
          <button type="submit" class="btn-small danger">削除</button>
        </form>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include('partials/footer') %>
