<%- include('../partials/header', { title: 'タスク一覧', currentUser }) %>

<%
  const STATUS_LABEL = { TODO: '未着手', IN_PROGRESS: '進行中', DONE: '完了' };
  const PRIORITY_LABEL = { HIGH: '高', MEDIUM: '中', LOW: '低' };
  const fmtDate = (d) => new Date(d).toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' });
%>

<h1>タスク</h1>

<!-- タスク追加フォーム -->
<details class="card" open>
  <summary>タスクを追加</summary>
  <form action="/tasks" method="post" class="form task-form">
    <label class="grow">タイトル
      <input type="text" name="title" placeholder="やること" required />
    </label>
    <label class="grow">説明（任意）
      <input type="text" name="description" placeholder="メモ" />
    </label>
    <label>状態
      <select name="status">
        <option value="TODO">未着手</option>
        <option value="IN_PROGRESS">進行中</option>
        <option value="DONE">完了</option>
      </select>
    </label>
    <label>優先度
      <select name="priority">
        <option value="HIGH">高</option>
        <option value="MEDIUM" selected>中</option>
        <option value="LOW">低</option>
      </select>
    </label>
    <label>期限
      <input type="date" name="dueDate" />
    </label>
    <label>カテゴリ
      <select name="categoryId">
        <option value="">なし</option>
        <% categories.forEach((c) => { %>
          <option value="<%= c.id %>"><%= c.name %></option>
        <% }) %>
      </select>
    </label>
    <button type="submit" class="btn-primary">追加</button>
  </form>
</details>

<!-- 絞り込み・並び替え -->
<form action="/tasks" method="get" class="filter-bar card">
  <label>状態
    <select name="status" onchange="this.form.submit()">
      <option value="">すべて</option>
      <% ['TODO','IN_PROGRESS','DONE'].forEach((s) => { %>
        <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= STATUS_LABEL[s] %></option>
      <% }) %>
    </select>
  </label>
  <label>優先度
    <select name="priority" onchange="this.form.submit()">
      <option value="">すべて</option>
      <% ['HIGH','MEDIUM','LOW'].forEach((p) => { %>
        <option value="<%= p %>" <%= filters.priority === p ? 'selected' : '' %>><%= PRIORITY_LABEL[p] %></option>
      <% }) %>
    </select>
  </label>
  <label>カテゴリ
    <select name="category" onchange="this.form.submit()">
      <option value="">すべて</option>
      <% categories.forEach((c) => { %>
        <option value="<%= c.id %>" <%= filters.category === String(c.id) ? 'selected' : '' %>><%= c.name %></option>
      <% }) %>
    </select>
  </label>
  <label>並び替え
    <select name="sort" onchange="this.form.submit()">
      <option value="" <%= filters.sort === '' ? 'selected' : '' %>>作成が新しい順</option>
      <option value="dueDate" <%= filters.sort === 'dueDate' ? 'selected' : '' %>>期限が近い順</option>
      <option value="priority" <%= filters.sort === 'priority' ? 'selected' : '' %>>優先度が高い順</option>
    </select>
  </label>
  <noscript><button type="submit">適用</button></noscript>
  <a class="muted clear-link" href="/tasks">クリア</a>
</form>

<!-- タスク一覧 -->
<% if (tasks.length === 0) { %>
  <p class="empty">表示するタスクがありません。上のフォームから追加しましょう。</p>
<% } else { %>
  <ul class="task-list">
    <% tasks.forEach((task) => { %>
      <%
        const done = task.status === 'DONE';
        const overdue = task.dueDate && !done && new Date(task.dueDate) < now;
      %>
      <li class="task-item priority-<%= task.priority.toLowerCase() %> <%= done ? 'done' : '' %>">
        <form action="/tasks/<%= task.id %>/toggle" method="post" class="inline toggle">
          <button type="submit" class="check" title="完了/未完了を切替"><%= done ? '☑' : '☐' %></button>
        </form>
        <div class="task-main">
          <div class="task-title"><%= task.title %></div>
          <% if (task.description) { %><div class="task-desc"><%= task.description %></div><% } %>
          <div class="task-meta">
            <span class="badge status"><%= STATUS_LABEL[task.status] %></span>
            <span class="badge prio prio-<%= task.priority.toLowerCase() %>">優先度: <%= PRIORITY_LABEL[task.priority] %></span>
            <% if (task.category) { %>
              <span class="badge cat" style="background: <%= task.category.color %>"><%= task.category.name %></span>
            <% } %>
            <% if (task.dueDate) { %>
              <span class="badge due <%= overdue ? 'overdue' : '' %>">期限: <%= fmtDate(task.dueDate) %><%= overdue ? '（超過）' : '' %></span>
            <% } %>
          </div>
        </div>
        <div class="task-actions">
          <a class="btn-small" href="/tasks/<%= task.id %>/edit">編集</a>
          <form action="/tasks/<%= task.id %>/delete" method="post" class="inline" onsubmit="return confirm('このタスクを削除しますか？');">
            <button type="submit" class="btn-small danger">削除</button>
          </form>
        </div>
      </li>
    <% }) %>
  </ul>
<% } %>

<%- include('../partials/footer') %>
