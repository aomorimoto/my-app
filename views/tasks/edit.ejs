<%- include('../partials/header', { title: 'タスク編集', currentUser }) %>

<%
  const dueValue = task.dueDate ? new Date(task.dueDate).toISOString().slice(0, 10) : '';
  const statuses = [['TODO','未着手'],['IN_PROGRESS','進行中'],['DONE','完了']];
  const priorities = [['HIGH','高'],['MEDIUM','中'],['LOW','低']];
%>

<h1>タスクを編集</h1>

<form action="/tasks/<%= task.id %>" method="post" class="form card edit-form">
  <label>タイトル
    <input type="text" name="title" value="<%= task.title %>" required />
  </label>
  <label>説明
    <textarea name="description" rows="3"><%= task.description || '' %></textarea>
  </label>
  <div class="row">
    <label>状態
      <select name="status">
        <% statuses.forEach(([v, l]) => { %>
          <option value="<%= v %>" <%= task.status === v ? 'selected' : '' %>><%= l %></option>
        <% }) %>
      </select>
    </label>
    <label>優先度
      <select name="priority">
        <% priorities.forEach(([v, l]) => { %>
          <option value="<%= v %>" <%= task.priority === v ? 'selected' : '' %>><%= l %></option>
        <% }) %>
      </select>
    </label>
    <label>期限
      <input type="date" name="dueDate" value="<%= dueValue %>" />
    </label>
    <label>カテゴリ
      <select name="categoryId">
        <option value="">なし</option>
        <% categories.forEach((c) => { %>
          <option value="<%= c.id %>" <%= task.categoryId === c.id ? 'selected' : '' %>><%= c.name %></option>
        <% }) %>
      </select>
    </label>
  </div>
  <div class="actions">
    <button type="submit" class="btn-primary">保存</button>
    <a class="btn-small" href="/tasks">キャンセル</a>
  </div>
</form>

<%- include('../partials/footer') %>
